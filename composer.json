{
  "name": "wyrihaximus-net/x-headers",
  "description": "The X-* headers emitted by WyriHaximus.net and other related services",
  "license": "MIT",
  "authors": [
    {
      "name": "Cees-Jan Kiewiet",
      "email": "ceesjank@gmail.com"
    }
  ],
  "require": {
    "php": "^8.4"
  },
  "require-dev": {
    "wyrihaximus/makefiles": "^0.11.0",
    "wyrihaximus/test-utilities": "^13.0.0"
  },
  "autoload": {
    "psr-4": {
      "WyriHaximusNet\\XHeaders\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "WyriHaximusNet\\Tests\\XHeaders\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "icanhazstring/composer-unused": true,
      "infection/extension-installer": true,
      "ocramius/package-versions": true,
      "phpstan/extension-installer": true,
      "wyrihaximus/makefiles": true,
      "wyrihaximus/test-utilities": true
    },
    "platform": {
      "php": "8.4.13"
    },
    "sort-packages": true
  },
  "scripts": {
    "post-install-cmd": [
      "make on-install-or-update || true"
    ],
    "post-update-cmd": [
      "make on-install-or-update || true"
    ]
  }
}
